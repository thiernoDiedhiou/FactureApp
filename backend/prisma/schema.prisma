// Prisma Schema - FactureApp Multi-Tenant
// Application de facturation XOF/UEMOA - Sénégal

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================
// Enums
// ========================

enum Plan {
  FREE       // 10 docs, 5 clients, 1 utilisateur
  STARTER    // 100 docs, 50 clients, 3 utilisateurs
  PRO        // illimité, 10 utilisateurs
  ENTERPRISE // illimité, utilisateurs illimités
}

enum MemberRole {
  OWNER  // créateur : droits complets + gestion plan
  ADMIN  // droits complets sauf facturation
  MEMBER // création + lecture, pas de suppression
}

// ========================
// Organisation (tenant)
// ========================

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique // ex: innosoft-creation
  plan      Plan     @default(FREE)
  suspended Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members         OrganizationMember[]
  clients         Client[]
  products        Product[]
  documents       Document[]
  settings        Settings?
  upgradeRequests UpgradeRequest[]

  @@map("organizations")
}

model OrganizationMember {
  id             String     @id @default(uuid())
  organizationId String     @map("organization_id")
  userId         String     @map("user_id")
  role           MemberRole @default(MEMBER)
  createdAt      DateTime   @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

// ========================
// Utilisateur (identité globale)
// ========================

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  isSuperAdmin        Boolean   @default(false) @map("is_super_admin")
  isEmailVerified     Boolean   @default(false) @map("is_email_verified")
  emailVerifyToken    String?   @unique @map("email_verify_token")
  passwordResetToken  String?   @unique @map("password_reset_token")
  passwordResetExpiry DateTime? @map("password_reset_expiry")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  memberships   OrganizationMember[]
  refreshTokens RefreshToken[]
  documents     Document[]           @relation("CreatedBy")

  @@map("users")
}

// ========================
// Clients (appartiennent à l'organisation)
// ========================

model Client {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  address        String?
  phone          String?
  email          String?
  companyName    String?  @map("company_name")
  ninea          String?  // Numéro fiscal sénégalais
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documents    Document[]

  @@map("clients")
}

// ========================
// Produits & Services
// ========================

model Product {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  description    String?
  price          Float    // Prix en XOF
  tvaRate        Float    @default(18) @map("tva_rate") // TVA Sénégal 18%
  category       String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documentItems DocumentItem[]

  @@map("products")
}

// ========================
// Documents (Factures, Devis, Proforma)
// ========================

model Document {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  clientId       String    @map("client_id")
  createdBy      String    @map("created_by") // userId pour audit
  type           String    // devis | facture | proforma
  number         String    // Ex: FAC-2024-001 (unique par org)
  status         String    @default("en_attente") // en_attente | paye | annule
  totalHt        Float     @default(0) @map("total_ht")
  totalTva       Float     @default(0) @map("total_tva")
  totalTtc       Float     @default(0) @map("total_ttc")
  discount       Float     @default(0) // Remise en %
  issuedDate     DateTime  @map("issued_date")
  dueDate        DateTime? @map("due_date")
  paidAt         DateTime? @map("paid_at")
  notes          String?
  originalId     String?   @map("original_id") // Pour les conversions/duplications
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client         @relation(fields: [clientId], references: [id])
  creator      User           @relation("CreatedBy", fields: [createdBy], references: [id])
  items        DocumentItem[]
  emailLogs    EmailLog[]

  @@unique([organizationId, number]) // numérotation unique par organisation
  @@map("documents")
}

model DocumentItem {
  id          String  @id @default(uuid())
  documentId  String  @map("document_id")
  productId   String? @map("product_id")
  description String
  quantity    Float
  unitPrice   Float   @map("unit_price") // Prix unitaire en XOF
  tvaRate     Float   @map("tva_rate")
  subtotal    Float   // Montant TTC de la ligne

  document Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  product  Product?  @relation(fields: [productId], references: [id])

  @@map("document_items")
}

// ========================
// Paramètres (niveau organisation)
// ========================

model Settings {
  id              String  @id @default(uuid())
  organizationId  String  @unique @map("organization_id")
  logoPath        String? @map("logo_path")
  companyName     String? @map("company_name")
  address         String?
  phone           String?
  email           String?
  website         String?
  ninea           String? // NINEA sénégalais
  defaultLanguage String  @default("fr") @map("default_language")
  defaultCurrency String  @default("XOF") @map("default_currency")
  defaultTvaRate  Float   @default(18) @map("default_tva_rate")
  documentStyle   String  @default("classique") @map("document_style")
  primaryColor    String  @default("#0EA5E9") @map("primary_color")
  signaturePath   String? @map("signature_path")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("settings")
}

// ========================
// Configuration des plans (géré par Super Admin)
// ========================

model PlanConfig {
  id           String   @id @default(uuid())
  key          Plan     @unique // FREE | STARTER | PRO | ENTERPRISE
  price        Int      @default(0)    // Prix en FCFA/mois (0 = gratuit)
  maxMembers   Int      @default(1)    // -1 = illimité
  maxDocuments Int      @default(10)   @map("max_documents") // -1 = illimité
  maxClients   Int      @default(5)    @map("max_clients")   // -1 = illimité
  description  String   @default("")
  features     Json     @default("[]") // Liste affichée sur la page Plans
  isActive     Boolean  @default(true) @map("is_active")
  updatedAt    DateTime @updatedAt     @map("updated_at")

  @@map("plan_configs")
}

// ========================
// Auth
// ========================

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ========================
// Demandes de mise à niveau de plan
// ========================

model UpgradeRequest {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  targetPlan     Plan      @map("target_plan")
  amount         Int       // montant en FCFA
  paymentMethod  String    @map("payment_method") // wave | orange_money | free_money | cash
  transactionRef String?   @map("transaction_ref")
  status         String    @default("pending")    // pending | validated | rejected
  notes          String?   // note admin (raison rejet)
  createdAt      DateTime  @default(now()) @map("created_at")
  processedAt    DateTime? @map("processed_at")
  processedBy    String?   @map("processed_by")  // userId super admin

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("upgrade_requests")
}

// ========================
// Configuration globale de la plateforme (Super Admin)
// ========================

model PlatformConfig {
  id           String   @id @default(uuid())
  paymentPhone String   @default("+221 77 328 73 76") @map("payment_phone")
  paymentName  String   @default("FactureApp")        @map("payment_name")
  supportEmail String   @default("contact@factureapp.sn") @map("support_email")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("platform_config")
}

model EmailLog {
  id         String   @id @default(uuid())
  documentId String   @map("document_id")
  sentTo     String   @map("sent_to")
  subject    String
  body       String?
  status     String   @default("sent") // sent | failed
  sentAt     DateTime @default(now()) @map("sent_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("email_logs")
}
