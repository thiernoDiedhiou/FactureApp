# ========================
# Environnement
# ========================
NODE_ENV=development
PORT=5000

# ========================
# Base de données
# ========================
# SQLite (développement)
DATABASE_URL="file:./dev.db"

# PostgreSQL (production)
# DATABASE_URL="postgresql://user:password@localhost:5432/factureapp"

# ========================
# JWT Configuration
# ========================
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret_change_in_production
REFRESH_TOKEN_EXPIRES_IN=7d

# ========================
# Email (Nodemailer SMTP)
# ========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre.email@gmail.com
SMTP_PASS=votre_mot_de_passe_app
EMAIL_FROM="CFActure <votre.email@gmail.com>"

# ========================
# Upload fichiers
# ========================
UPLOAD_MAX_SIZE=2097152
UPLOAD_PATH=./uploads

# ========================
# CORS
# ========================
FRONTEND_URL=http://localhost:3000

# ========================
# URL publique de l'API (pour les liens PDF WhatsApp)
# ========================
API_BASE_URL=http://localhost:5000

# ========================
# Rate Limiting
# ========================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
